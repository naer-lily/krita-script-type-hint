    Wrapper around KoFileDialog, which is a wrapper around QFileDialog, providing native file dialogs on KDE/Gnome/Windows/OSX/etc. `FileDialog` respects `Krita`'s "Don't use native file dialogs" setting.
    """

    class DialogType(int):
        OpenFile: ClassVar[FileDialog.DialogType]
        OpenFiles: ClassVar[FileDialog.DialogType]
        OpenDirectory: ClassVar[FileDialog.DialogType]
        ImportFile: ClassVar[FileDialog.DialogType]
        ImportFiles: ClassVar[FileDialog.DialogType]
        ImportDirectory: ClassVar[FileDialog.DialogType]
        SaveFile: ClassVar[FileDialog.DialogType]

    def __init__(self, parent: QWidget = None, arg1: FileDialog.DialogType = FileDialog.DialogType.OpenFile, dialogName: str = '') -> None:
        """
        constructor

        :returns: The name of the entry user selected in the file dialog

        :param parent: The parent of the file dialog
        :param dialogType: usage of the file dialog Valid arguments: 

        - FileDialog.DialogType.OpenFile

        - FileDialog.DialogType.OpenFiles

        - FileDialog.DialogType.OpenDirectory

        - FileDialog.DialogType.ImportFile

        - FileDialog.DialogType.ImportFiles

        - FileDialog.DialogType.ImportDirectory

        - FileDialog.DialogType.SaveFile 



        dialogName the name for the file dialog. This will be used to open the filedialog in the last open location, instead of the specified directory.
        """

        ...

    def filename(self) -> str:
        """
        Show the file dialog and return the file name the user selected.
        """

        ...

    def filenames(self) -> list[str]:
        """
        Show the file dialog and return multiple file names the user selected.
        """

        ...

    @staticmethod
    def getExistingDirectory(parent: QWidget = None, caption: str = "", directory: str = "", dialogName: str = "") -> str:
        """
        Create and show a file dialog and return the name of an existing directory selected by the user.

        :returns: the name of an existing directory selected by the user

        :param parent: Dialog parent widget
        :param caption: Dialog caption
        :param directory: Starting directory for the file dialog
        :param dialogName: Internal name of the dialog used for remembering the opened directory
        """

        ...

    @staticmethod
    def getOpenFileName(parent: QWidget = None, caption: str = "", directory: str = "", filter: str = "", selectedFilter: str = "", dialogName: str = "") -> str:
        """
        Create and show a file dialog and return the name of an existing file selected by the user.

