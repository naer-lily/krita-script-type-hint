        :param parent: Dialog parent widget
        :param caption: Dialog caption
        :param directory: Starting directory for the file dialog
        :param filter: Name filters for files shown
        :param selectedFilter: The selected name filter
        :param dialogName: Internal name of the dialog used for remembering the opened directory
        """

        ...

    @staticmethod
    def getOpenFileNames(parent: QWidget = None, caption: str = "", directory: str = "", filter: str = "", selectedFilter: str = "", dialogName: str = "") -> list[str]:
        """
        Create and show a file dialog and return the name of multiple existing files selected by the user.

        :returns: the name of multiple existing files selected by the user

        :param parent: Dialog parent widget
        :param caption: Dialog caption
        :param directory: Starting directory for the file dialog
        :param filter: Name filters for files shown
        :param selectedFilter: The selected name filter
        :param dialogName: Internal name of the dialog used for remembering the opened directory
        """

        ...

    @staticmethod
    def getSaveFileName(parent: QWidget = None, caption: str = "", directory: str = "", filter: str = "", selectedFilter: str = "", dialogName: str = "") -> str:
        """
        Create and show a file dialog and return the name of a file to save to selected by the user.

